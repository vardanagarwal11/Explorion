# =============================================================
# arXivisual Backend — Environment Variables
# =============================================================
# Copy this file to .env and fill in your keys:
#   cp .env.example .env
# =============================================================

# ---------------------------
# LLM / AI
# ---------------------------

# ---------------------------
# Dedalus SDK + MCP Gateway
# ---------------------------
# REQUIRED: LLM calls are Dedalus-only in this project.
# The official Dedalus SDK (dedalus-labs) reads this env var automatically.
# Sign up at https://www.dedaluslabs.ai/dashboard/api-keys to get your key.
DEDALUS_API_KEY=your-dedalus-api-key-here

# ---------------------------
# GitHub (for repo explainer)
# ---------------------------
# Optional: Without a token, GitHub API is limited to 60 requests/hour.
# With a token, you get 5,000 requests/hour.
# Generate at: https://github.com/settings/tokens (no special scopes needed for public repos)
# GITHUB_TOKEN=your-github-token-here

# ---------------------------
# Text-to-Speech (TTS)
# ---------------------------
# Default: "gtts" (free, decent quality, multi-language)
# Options: "gtts", "openai", "elevenlabs"
TTS_PROVIDER=gtts

# OpenAI TTS (only needed when TTS_PROVIDER=openai)
# Sign up at: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-your-openai-api-key

# ElevenLabs TTS (only needed when TTS_PROVIDER=elevenlabs)
# Sign up at: https://elevenlabs.io/
# ELEVENLABS_API_KEY=your-elevenlabs-api-key

# ---------------------------
# Storage Mode
# ---------------------------
# "local" (default) — files stored in ./media/videos/
# "r2" — Cloudflare R2 cloud storage
STORAGE_MODE=local

# ---------------------------
# Cloudflare R2 (only needed when STORAGE_MODE=r2)
# ---------------------------
# S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# S3_BUCKET=arxiviz-videos
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_PUBLIC_URL=https://videos.arxiviz.org

# ---------------------------
# Modal.com
# Run `modal token new` to get your token.
# ---------------------------
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=
RENDER_MODE=modal

# ---------------------------
# API Server
# ---------------------------
API_HOST=0.0.0.0
API_PORT=8000

