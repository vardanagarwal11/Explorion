# =============================================================
# Explorion Backend — Environment Variables
# =============================================================

# ---------------------------
# Cloud AI APIs
# ---------------------------
GROQ_API_KEY=your-groq-api-key-here
NIM_API_KEY=your-nim-api-key-here

# Model configuration (optional overrides)
SUMMARY_MODEL=llama-3.3-70b-versatile
CODE_MODEL=meta/llama-3.3-70b-instruct

# ---------------------------
# GitHub (for repo explainer)
# ---------------------------
GITHUB_TOKEN=your-github-token-here

# ---------------------------
# Text-to-Speech (TTS)
# ---------------------------
TTS_PROVIDER=gtts

# ---------------------------
# Storage Mode
# ---------------------------
STORAGE_MODE=local
RENDER_MODE=local

# ---------------------------
# Manim Rendering
# ---------------------------
MANIM_QUALITY_FLAG=-ql

# ---------------------------
# API Server
# ---------------------------
API_HOST=0.0.0.0
API_PORT=8000
